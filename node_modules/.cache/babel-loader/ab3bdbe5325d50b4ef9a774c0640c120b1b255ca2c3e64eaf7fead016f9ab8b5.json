{"ast":null,"code":"import{useEffect}from'react';import{useMap,useMapEvents}from'react-leaflet';export function MapClickHandler(_ref){let{onSelect}=_ref;useMapEvents({click(event){onSelect({latitude:event.latlng.lat,longitude:event.latlng.lng});}});return null;}export function RecenterMap(_ref2){let{center}=_ref2;const map=useMap();useEffect(()=>{map.setView(center,Math.max(map.getZoom(),5));},[center,map]);return null;}","map":{"version":3,"names":["useEffect","useMap","useMapEvents","MapClickHandler","_ref","onSelect","click","event","latitude","latlng","lat","longitude","lng","RecenterMap","_ref2","center","map","setView","Math","max","getZoom"],"sources":["C:/Users/User/Desktop/pogoda (2)/pogoda/weather-project-frontend/src/components/MapHelpers.tsx"],"sourcesContent":["import { useEffect } from 'react';\nimport { useMap, useMapEvents } from 'react-leaflet';\nimport type { CoordinatePoint } from '../types';\n\nexport function MapClickHandler({\n  onSelect,\n}: {\n  onSelect: (point: CoordinatePoint) => void;\n}) {\n  useMapEvents({\n    click(event) {\n      onSelect({\n        latitude: event.latlng.lat,\n        longitude: event.latlng.lng,\n      });\n    },\n  });\n\n  return null;\n}\n\nexport function RecenterMap({ center }: { center: [number, number] }) {\n  const map = useMap();\n\n  useEffect(() => {\n    map.setView(center, Math.max(map.getZoom(), 5));\n  }, [center, map]);\n\n  return null;\n}\n"],"mappings":"AAAA,OAASA,SAAS,KAAQ,OAAO,CACjC,OAASC,MAAM,CAAEC,YAAY,KAAQ,eAAe,CAGpD,MAAO,SAAS,CAAAC,eAAeA,CAAAC,IAAA,CAI5B,IAJ6B,CAC9BC,QAGF,CAAC,CAAAD,IAAA,CACCF,YAAY,CAAC,CACXI,KAAKA,CAACC,KAAK,CAAE,CACXF,QAAQ,CAAC,CACPG,QAAQ,CAAED,KAAK,CAACE,MAAM,CAACC,GAAG,CAC1BC,SAAS,CAAEJ,KAAK,CAACE,MAAM,CAACG,GAC1B,CAAC,CAAC,CACJ,CACF,CAAC,CAAC,CAEF,MAAO,KAAI,CACb,CAEA,MAAO,SAAS,CAAAC,WAAWA,CAAAC,KAAA,CAA2C,IAA1C,CAAEC,MAAqC,CAAC,CAAAD,KAAA,CAClE,KAAM,CAAAE,GAAG,CAAGf,MAAM,CAAC,CAAC,CAEpBD,SAAS,CAAC,IAAM,CACdgB,GAAG,CAACC,OAAO,CAACF,MAAM,CAAEG,IAAI,CAACC,GAAG,CAACH,GAAG